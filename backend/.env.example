# Copy to `.env` and fill real values, then run: `docker compose up -d`
# - DO NOT commit your real `.env`
# - This file is only a template

# ===== MySQL container (docker-compose.yml) =====
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=wxcheckin_ext
MYSQL_USER=wxcheckin
MYSQL_PASSWORD=wxcheckin

# ===== Backend runtime =====
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# --- Ext DB: wxcheckin_ext ---
DB_HOST=mysql
DB_PORT=3306
DB_NAME=wxcheckin_ext
DB_USER=wxcheckin
DB_PASSWORD=wxcheckin

# --- Legacy DB: suda_union ---
LEGACY_DB_URL=jdbc:mysql://mysql:3306/suda_union?useUnicode=true&characterEncoding=UTF-8&serverTimezone=UTC&allowPublicKeyRetrieval=true&useSSL=false
LEGACY_DB_USER=wxcheckin
LEGACY_DB_PASSWORD=wxcheckin

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Web Auth（账号密码） ---
# - 账号：student_id（学号）
# - 默认密码：123（只保存 bcrypt hash，不保存明文）
# - 首次登录后强制改密：未改密前业务接口会返回 password_change_required

# --- Dynamic code / Security (REQUIRED in real prod) ---
# - 仍沿用历史环境变量名 `QR_SIGNING_KEY`，但用途已切换为“动态 6 位码生成与验码”。
QR_SIGNING_KEY=replace-this-before-prod
# Retention/cleanup (seconds / ms)
QR_REPLAY_GUARD_RETENTION_SECONDS=0
QR_CLEANUP_ENABLED=true
QR_CLEANUP_INTERVAL_MS=300000
SESSION_TTL_SECONDS=7200

# --- Risk control (optional) ---
# 动态码错误尝试限流（建议保留默认；如需可按压测调整）
RISK_INVALID_CODE_MAX_ATTEMPTS_PER_USER=12
RISK_INVALID_CODE_WINDOW_SECONDS=60

# --- Sync (prod requires true) ---
LEGACY_SYNC_ENABLED=true
LEGACY_SYNC_INTERVAL_MS=2000
OUTBOX_RELAY_ENABLED=true
OUTBOX_RELAY_INTERVAL_MS=1000
