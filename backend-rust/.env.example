# wxapp-checkin Rust 后端本地联调示例
#
# 使用方式：
# 1. `./scripts/bootstrap.sh` 会把本文件复制为 `backend-rust/.env.local.sh`
# 2. `./scripts/dev.sh local` 会 source 该文件后启动 `cargo run`

DATABASE_URL=mysql://root:root@127.0.0.1:3306/suda_union
SERVER_PORT=9989
SESSION_TTL_SECONDS=7200
QR_SIGNING_KEY=replace-this-before-prod
TOKIO_WORKER_THREADS=2
MYSQL_MAX_CONNECTIONS=4
