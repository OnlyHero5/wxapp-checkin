# 这份文件展示了 `docker/compose.override.env` 的推荐写法。
# 默认只需要按需填写外部 `suda_union` 的 3 个值。
# 若保持为空，系统会自动回退到 compose 内 demo `suda_union`，
# 并在启动日志里明确提示“当前是单项目演示状态，非生产在线状态”。

# ===== 如需接外部 suda_union，只填写下面 3 项 =====
# 示例：
# SUDA_UNION_DB_HOST=192.168.1.20
# SUDA_UNION_DB_USER=wxcheckin_app
# SUDA_UNION_DB_PASSWORD=请填真实数据库密码
SUDA_UNION_DB_HOST=
SUDA_UNION_DB_USER=
SUDA_UNION_DB_PASSWORD=
