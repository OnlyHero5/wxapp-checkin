# wxapp-checkin 云服务器 / Docker 部署示例。
# 使用方式：
# 1. 复制为仓库根目录 `.env.docker`
# 2. 按实际环境填写 suda-union 账号密码与签名密钥
# 3. 执行 `./scripts/docker-prod.sh`

# suda-union 连接配置：
# - 主机名默认就是三容器网络里的 `suda-union`
# - 端口按当前确认值锁定为 3499
SUDA_UNION_DB_HOST=suda-union
SUDA_UNION_DB_PORT=3499
SUDA_UNION_DB_NAME=suda_union
SUDA_UNION_DB_USER=wxcheckin_app
SUDA_UNION_DB_PASSWORD=replace-with-real-password

# wxapp-checkin 对外入口配置。
WXAPP_HTTP_PORT=89
WXAPP_INTERNAL_PORT=8080
WXAPP_QR_SIGNING_KEY=replace-this-before-prod
WXAPP_SESSION_TTL_SECONDS=7200
WXAPP_TOKIO_WORKER_THREADS=2
WXAPP_MYSQL_MAX_CONNECTIONS=4

# 三项目联调默认仍走同一条 Docker 网络。
DOCKER_NETWORK=three-projects-net
