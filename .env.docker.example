# wxapp-checkin 云服务器 / Docker 部署示例。
# 使用方式：
# 1. 复制为仓库根目录 `.env.docker`
# 2. 按实际环境填写 suda-union 账号密码与签名密钥
# 3. 执行 `./scripts/docker-prod.sh`

# suda-union 连接配置：
# - 当前 Docker 发布把 host / port / db / user / password 统一收口到这个文件；
# - 生产环境只需要改这里，不要再去脚本、Compose 或文档里分散找硬编码；
# - 当前云服务器口径改为回连宿主机暴露的 MySQL 端口，因此主机名走 `host.docker.internal`
# - 示例里宿主机映射口使用 `3317`；容器内 `suda_union` 仍保持 `3499`
# - 端口仍单独保留在 `SUDA_UNION_DB_PORT`，不要把 `:3317` 再拼进 `SUDA_UNION_DB_HOST`，否则 DSN 会变成双端口
SUDA_UNION_DB_HOST=host.docker.internal
SUDA_UNION_DB_PORT=3317
SUDA_UNION_DB_NAME=suda_union
SUDA_UNION_DB_USER=suda_union
SUDA_UNION_DB_PASSWORD=123456

# wxapp-checkin 对外入口配置。
WXAPP_HTTP_PORT=89
WXAPP_INTERNAL_PORT=8080
# `WXAPP_QR_SIGNING_KEY` 生成示例（Python 3）：
# python3 - <<'PY'
# import secrets
# print(secrets.token_urlsafe(48))
# PY
# 上面命令的一次生成示例：
WXAPP_QR_SIGNING_KEY_SAMPLE=BzxCMreEohjIgJrWTZ2C7M1JrKAK_OlqqJeMJUbizP9ENaXLumRYGMN4VFhL4G6F
WXAPP_QR_SIGNING_KEY=replace-with-generated-secret
WXAPP_SESSION_TTL_SECONDS=7200
WXAPP_TOKIO_WORKER_THREADS=2
WXAPP_MYSQL_MAX_CONNECTIONS=4

# 控制 Docker 终端日志滚动，避免云服务器磁盘被日志持续吃满。
WXAPP_DOCKER_LOG_MAX_SIZE=5m
WXAPP_DOCKER_LOG_MAX_FILE=2

# 三项目联调默认仍走同一条 Docker 网络。
DOCKER_NETWORK=three-projects-net
